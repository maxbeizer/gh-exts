Output demo.gif
Set Shell bash
Set FontSize 14
Set Width 900
Set Height 550
Set Theme "Catppuccin Mocha"
Set Padding 15

Type "gh exts"
Sleep 300ms
Enter
Sleep 4s

# Filter to find an extension
Type "/contrib"
Sleep 1s
Enter
Sleep 1s

# Select it to view README
Enter
Sleep 5s

# Scroll down
Down 5
Sleep 2s

# Go back and quit
Escape
Sleep 1s
Type "q"
Sleep 500ms
